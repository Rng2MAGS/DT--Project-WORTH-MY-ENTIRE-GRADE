[gd_scene format=3 uid="uid://dydpswsiefbxk"]

[sub_resource type="GDScript" id="GDScript_4icm7"]
resource_name = "ship"
script/source = "extends CharacterBody2D


var speed = 500.0
var can_shoot: bool = true


@export var pivot: Node2D
@export var bullet_spawn: Marker2D
@export var bullet_timer: Timer
@export var player_health: int


func _physics_process(_delta: float) -> void:
	# Define direction
	var direction: Vector2 = Vector2(0.0, 0.0)
	# Get input direction and set the characters' velocity
	direction.y = Input.get_axis(\"ui_up\", \"ui_down\")
	if direction.y:
		velocity.y = direction.y * speed
	else:
		velocity.y = move_toward(velocity.x, 0, speed)
	direction.x = Input.get_axis(\"ui_left\", \"ui_right\")
	if direction.x:
		velocity.x = direction.x * speed
	else:
		velocity.x = move_toward(velocity.x, 0, speed)
	#Prevent excess speed
	velocity = speed * direction.normalized()
	move_and_slide()
	
	
func _bullet_timer() -> void:
	can_shoot = true
	
	
	
func _shooting() -> void:
	var shoot = Input.get(\"ui_accept\")
	if can_shoot == true:
		
		can_shoot = false
		
	pass # Replace with function body.
	
	
	
	
	
	
	
	
	
"

